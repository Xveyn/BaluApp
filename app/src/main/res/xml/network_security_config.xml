<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        DEVELOPMENT BUILD CONFIGURATION
        ================================
        For local NAS access, we allow HTTP traffic to private networks.

        SECURITY NOTICE: This is acceptable for a NAS app because:
        1. Users typically access their NAS on local/private networks
        2. Private networks (home WiFi) are already trusted
        3. The app still supports HTTPS when available

        For a production public-facing app, this should be locked down to
        require HTTPS with certificate pinning.
    -->

    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>

    <!-- Trust self-signed BaluHost NAS certificate -->
    <domain-config>
        <domain includeSubdomains="true">baluhost.local</domain>
        <domain includeSubdomains="true">baluhost</domain>
        <domain includeSubdomains="true">192.168.178.53</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="@raw/baluhost_cert" />
        </trust-anchors>
    </domain-config>
</network-security-config>
